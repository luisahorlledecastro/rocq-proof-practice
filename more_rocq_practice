(* Practice manipulating logical AND (/\) using destruct and split *)
Lemma and_commutativity : forall P Q : Prop, P /\ Q -> Q /\ P.
Proof.
  intros P Q H.
  destruct H.
  split.
  - apply H0.
  - apply H.

Qed.


